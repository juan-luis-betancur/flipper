SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# HS256 (legacy): JWT secret del dashboard. ES256/RS256 (nuevo): puede quedar vacío si validas solo con JWKS; SUPABASE_URL obligatorio.
SUPABASE_JWT_SECRET=
# Secreto compartido con el programador HTTP (Render/Railway/cron-job.org, etc.).
# Genera uno fuerte, p. ej.: openssl rand -hex 32   (vacío = el endpoint /api/cron/daily-scrape responde 403)
CRON_SECRET=
TELEGRAM_WEBHOOK_SECRET=change-me
SCRAPE_DELAY_SECONDS=3.5
SCRAPE_MAX_PROPERTIES=100

# --- Mercado Libre anti-bot ---
# Cookie del navegador (Cookie header copiado tras resolver el challenge manualmente).
# Útil como fallback si el PoW falla; caduca en ~24h.
# ML_COOKIE=
# Proxy residencial para ML. Formato: http://user:pass@host:port
# Las IPs de datacenter (Railway/Render/Fly/etc.) son bloqueadas por Akamai Bot Manager.
# Con un proxy residencial el scraper funciona desde cualquier host.
# Proveedores sugeridos: Decodo (~$3.5/GB), IPRoyal (~$1.75/GB), Bright Data.
# ML_PROXY_URL=
# Opcional: ScrapingBee API key como fallback si no quieres contratar proxy directo.
# SCRAPINGBEE_API_KEY=
